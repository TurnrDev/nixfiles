#!/usr/bin/env bash

set -u

CONFIG_PATH="${CONFIG_PATH:-${XDG_CONFIG_HOME:-$HOME/.config}/dockmgr/config.json}"
DOCK_POLL_INTERVAL="${DOCK_POLL_INTERVAL:-2}"
DOCK_UDEV_SETTLE_DELAY="${DOCK_UDEV_SETTLE_DELAY:-1}"
DOCK_NOTIFY_APP="${DOCK_NOTIFY_APP:-dockmgr}"

trap 'exit 130' INT
trap 'exit 143' TERM

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        printf 'dockmgr: missing required command: %s\n' "$1" >&2
        exit 1
    }
}

quick_notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -a "$DOCK_NOTIFY_APP" "$1" >/dev/null 2>&1 || true
    fi
}

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -a "$DOCK_NOTIFY_APP" "$1" "$2" >/dev/null 2>&1 || true
    fi
}

ensure_config() {
    [ -r "$CONFIG_PATH" ] || {
        printf 'dockmgr: missing config: %s\n' "$CONFIG_PATH" >&2
        exit 1
    }
}

read_usb_ids() {
    local vendor_file device_dir product_file got_vendor got_product

    for vendor_file in /sys/bus/usb/devices/*/idVendor; do
        [ -e "$vendor_file" ] || continue

        device_dir="${vendor_file%/idVendor}"
        product_file="$device_dir/idProduct"
        [ -r "$vendor_file" ] || continue
        [ -r "$product_file" ] || continue

        read -r got_vendor < "$vendor_file" || continue
        read -r got_product < "$product_file" || continue
        printf '%s:%s\n' "$got_vendor" "$got_product"
    done | sort -u
}

read_connected_display_names() {
    local status_file output_name status_value

    for status_file in /sys/class/drm/card*-*/status; do
        [ -r "$status_file" ] || continue
        read -r status_value < "$status_file" || continue
        [ "$status_value" = "connected" ] || continue

        output_name="$(basename "${status_file%/status}")"
        output_name="${output_name#*-}"
        printf '%s\n' "$output_name"
    done | sort -u
}

read_connected_display_descriptions() {
    command -v hyprctl >/dev/null 2>&1 || return 0

    hyprctl monitors all -j 2>/dev/null \
        | jq -r '.[] | .description? // empty | select(length > 0) | "desc:" + .' 2>/dev/null \
        | sort -u || true
}

read_lid_closed() {
    local lid_state_file lid_value

    for lid_state_file in /proc/acpi/button/lid/*/state; do
        [ -r "$lid_state_file" ] || continue
        lid_value="$(awk '{ print $2 }' "$lid_state_file" 2>/dev/null)" || continue
        case "$lid_value" in
            closed)
                printf 'true\n'
                return 0
                ;;
            open)
                printf 'false\n'
                return 0
                ;;
        esac
    done

    printf 'false\n'
}

collect_state() {
    local usb_json display_json description_json merged_display_json lid_closed

    usb_json="$(read_usb_ids | jq -R . | jq -s .)"
    display_json="$(read_connected_display_names | jq -R . | jq -s .)"
    description_json="$(read_connected_display_descriptions | jq -R . | jq -s .)"
    merged_display_json="$(jq -cn --argjson names "$display_json" --argjson descriptions "$description_json" '$names + $descriptions | unique')"
    lid_closed="$(read_lid_closed)"

    jq -cn \
        --argjson usb "$usb_json" \
        --argjson displays "$merged_display_json" \
        --argjson lidClosed "$lid_closed" \
        '{
            usb: $usb,
            displays: $displays,
            lid: {
                closed: $lidClosed
            }
        }'
}

select_profile() {
    local state_json="$1"

    jq -cn \
        --rawfile configText "$CONFIG_PATH" \
        --argjson state "$state_json" '
        ($configText | fromjson) as $config
        |
        def containsValue($haystack; $needle):
            any($haystack[]?; . == $needle);
        def allContained($haystack; $needles):
            all($needles[]?; containsValue($haystack; .));
        def anyContained($haystack; $needles):
            any($needles[]?; containsValue($haystack; .));
        def noneContained($haystack; $needles):
            all($needles[]?; containsValue($haystack; .) | not);
        def evalExpr($expr; $state):
            all(
                $expr
                | to_entries[];
                if .key == "and" then
                    all(.value[]?; evalExpr(.; $state))
                elif .key == "or" then
                    any(.value[]?; evalExpr(.; $state))
                elif .key == "not" then
                    evalExpr(.value; $state) | not
                elif .key == "usb" then
                    (
                        (.value.anyOf? | if . == null then true else anyContained($state.usb; .) end)
                        and (.value.allOf? | if . == null then true else allContained($state.usb; .) end)
                        and (.value.noneOf? | if . == null then true else noneContained($state.usb; .) end)
                    )
                elif .key == "displays" then
                    (
                        (.value.connectedAnyOf? | if . == null then true else anyContained($state.displays; .) end)
                        and (.value.connectedAllOf? | if . == null then true else allContained($state.displays; .) end)
                        and (.value.connectedNoneOf? | if . == null then true else noneContained($state.displays; .) end)
                    )
                elif .key == "lid" then
                    $state.lid.closed == .value.closed
                else
                    false
                end
            );
        def rank:
            [(.specificity // 0), (-(.order // 0))];
        ($config.profiles // []) as $profiles
        | ($profiles | map(select(.match != null and evalExpr(.match; $state))) | sort_by(rank) | last) as $matched
        | ($profiles | map(select(.fallback)) | sort_by(rank) | last) as $fallback
        | ($matched // $fallback // empty)
        '
}

run_hook_list() {
    local profile_name="$1"
    local phase="$2"
    local commands_json="$3"

    jq -r '.[]' <<<"$commands_json" | while IFS= read -r command; do
        [ -n "$command" ] || continue
        if ! bash -lc "$command"; then
            printf 'dockmgr: hook failed: %s %s: %s\n' "$profile_name" "$phase" "$command" >&2
            notify "dockmgr hook failed" "$profile_name $phase failed"
        fi
    done
}

apply_profile() {
    local profile_json="$1"
    local profile_name

    profile_name="$(jq -r '.name' <<<"$profile_json")"
    if ! dms ipc outputs setProfile "$profile_name" >/dev/null 2>&1; then
        printf 'dockmgr: failed to apply DMS profile: %s\n' "$profile_name" >&2
        notify "dockmgr apply failed" "Unable to activate $profile_name"
        return 1
    fi

    return 0
}

transition_profile() {
    local from_json="$1"
    local to_json="$2"
    local from_name to_name

    to_name="$(jq -r '.name' <<<"$to_json")"

    if [ -n "$from_json" ]; then
        from_name="$(jq -r '.name' <<<"$from_json")"
        notify "Switching profile" "$from_name -> $to_name"
        run_hook_list "$from_name" "preDown" "$(jq -c '.hooks.preDown // []' <<<"$from_json")"
    else
        notify "Activating profile" "$to_name"
    fi

    run_hook_list "$to_name" "preUp" "$(jq -c '.hooks.preUp // []' <<<"$to_json")"
    apply_profile "$to_json"

    if [ -n "$from_json" ]; then
        run_hook_list "$from_name" "postDown" "$(jq -c '.hooks.postDown // []' <<<"$from_json")"
    fi

    run_hook_list "$to_name" "postUp" "$(jq -c '.hooks.postUp // []' <<<"$to_json")"
    notify "Profile active" "$to_name"
}

current_profile_json() {
    local state_json
    state_json="$(collect_state)"
    select_profile "$state_json"
}

print_status() {
    local state_json profile_json

    state_json="$(collect_state)"
    profile_json="$(select_profile "$state_json")"

    printf 'State:\n'
    jq . <<<"$state_json"
    printf '\nSelected profile:\n'
    if [ -n "$profile_json" ]; then
        jq . <<<"$profile_json"
    else
        printf 'None\n'
    fi
}

check_transition() {
    local current_json current_id

    current_json="$(current_profile_json)"
    [ -n "$current_json" ] || {
        printf 'dockmgr: no profile matched and no fallback is configured\n' >&2
        return 1
    }

    current_id="$(jq -r '.id' <<<"$current_json")"

    if [ "${last_profile_id:-}" != "$current_id" ]; then
        transition_profile "${last_profile_json:-}" "$current_json"
        last_profile_json="$current_json"
        last_profile_id="$current_id"
    fi
}

watch_udev() {
    udevadm monitor --udev 2>/dev/null | while IFS= read -r _event; do
        sleep "$DOCK_UDEV_SETTLE_DELAY"
        check_transition || true
    done
    return 1
}

watch_poll() {
    while :; do
        check_transition || true
        sleep "$DOCK_POLL_INTERVAL"
    done
}

watch() {
    ensure_config
    need_cmd jq
    need_cmd dms

    last_profile_id=""
    last_profile_json=""
    check_transition

    if command -v udevadm >/dev/null 2>&1; then
        watch_udev &
        udev_pid=$!
        trap 'kill "$udev_pid" 2>/dev/null || true; exit 130' INT
        trap 'kill "$udev_pid" 2>/dev/null || true; exit 143' TERM
    else
        printf 'dockmgr: udev monitor unavailable; polling every %ss\n' "$DOCK_POLL_INTERVAL" >&2
    fi

    watch_poll
}

once() {
    local current_json

    ensure_config
    need_cmd jq
    need_cmd dms

    current_json="$(current_profile_json)"
    [ -n "$current_json" ] || {
        printf 'dockmgr: no profile matched and no fallback is configured\n' >&2
        exit 1
    }

    transition_profile "" "$current_json"
}

usage() {
    cat <<'EOF'
Usage:
  dockmgr watch      Watch dock state and switch profiles
  dockmgr status     Print current state and selected profile
  dockmgr once       Run the current profile activation once

Environment overrides:
  DOCK_POLL_INTERVAL      default: 2 unit: seconds
  DOCK_UDEV_SETTLE_DELAY  default: 1 unit: seconds
  DOCK_NOTIFY_APP         default: dockmgr
  CONFIG_PATH             default: $XDG_CONFIG_HOME/dockmgr/config.json
EOF
}

case "${1:-watch}" in
    watch)
        watch
        ;;
    status)
        ensure_config
        need_cmd jq
        print_status
        ;;
    once)
        once
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
